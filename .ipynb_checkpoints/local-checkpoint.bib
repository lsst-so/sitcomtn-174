@article{krause2017, title={CosmoLike - Cosmological Likelihood Analyses for Photometric Galaxy Surveys}, volume={470}, ISSN={0035-8711, 1365-2966}, DOI={10.1093/mnras/stx1261}, abstractNote={We explore strategies to extract cosmological constraints from a joint analysis of cosmic shear, galaxy-galaxy lensing, galaxy clustering, cluster number counts, and cluster weak lensing. We utilize the CosmoLike software to simulate results from an LSST like data set, speciﬁcally, we 1) compare individual and joint analyses of the diﬀerent probes, 2) vary the selection criteria for lens and source galaxies, 3) investigate the impact of blending, 4) investigate the impact of the assumed cosmological model in multi-probe covariances, 6) quantify information content as a function of scales, and 7) explore the impact of intrinsic galaxy alignment in a multiprobe context. Our analyses account for all cross correlations within and across probes and include the higher-order (non-Gaussian) terms in the multi-probe covariance matrix. We simultaneously model cosmological parameters and a variety of systematics, e.g. uncertainties arising from shear and photo-z calibration, cluster mass-observable relation, galaxy intrinsic alignment, and galaxy bias (up to 54 parameters altogether).}, note={arXiv:1601.05779 [astro-ph]}, number={2}, journal={Monthly Notices of the Royal Astronomical Society}, author={Krause, Elisabeth and Eifler, Tim}, year={2017}, month=sep, pages={2100–2112}, language={en} }
 

